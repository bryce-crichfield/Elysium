<!-- elysium/invoke.xml -->
<Protocol version="1">

    <!-- Connection -->
    <Procedure name="Ping" id="0xFF">
        <Request>
            <Field name="client_tick" type="u32"/>
        </Request>
        <Response>
            <Field name="server_tick"      type="u32"/>
            <Field name="echo_client_tick" type="u32"/>
        </Response>
    </Procedure>

    <!-- Player -->
    <Procedure name="SpawnPlayer" id="0x01">
        <Request>
            <Field name="scene_id"    type="u32"/>
            <Field name="player_name" type="string"/>
        </Request>
        <Response>
            <Field name="entity_id" type="u32"/>
            <Field name="success"   type="bool"/>
        </Response>
    </Procedure>


</Protocol>