 <CharacterTypes>
    <CharacterType id="KNIGHT">
        <!-- Default components when spawning this type -->
        <StatsComponent hp="100" str="15" def="12" />
        <SpriteComponent sprite="knight_idle" />
        <AnimationComponent />
        <OverworldAiComponent>
            <!-- AI is just conditional animation sequences -->
            <Behavior name="patrol">
                <Repeat times="-1">
                    <MoveTo x="5" y="3" duration="2.0"/>
                    <Wait duration="1.0"/>
                    <MoveTo x="8" y="3" duration="2.0"/>
                    <Wait duration="1.0"/>
                    <IfPlayerInRange range="3">
                        <InterruptWith behavior="chase"/>
                    </IfPlayerInRange>
                </Repeat>
            </Behavior>
        </OverworldAiComponent>
    </CharacterType>

    <CharacterType name="MAGE">
        <BattleAiComponent type="tactical">
            <TurnStrategy>
                <TargetStrategy>
                    <Score target="archer" value="10" />
                    <Score target="mage" value="9" />
                    <Score target="low_hp" value="8" />
                    <Score target="tank" value="2" />
                </TargetStrategy>

                <ActionStrategy>
                    <Action name="meteor" preference="grouped_enemies" />
                    <Action name="fireball" preference="default" />
                    <Action name="magic_missile" preference="low_hp" />
                </ActionStrategy>

                <PositionStrategy>
                    <Preference type="max_range" weight="8" />
                    <Preference type="cover" weight="6" />
                    <Preference type="avoid_melee" weight="10" />
                </PositionStrategy>
            </TurnStrategy>
        </BattleAiComponent>

        <ActionsComponent>
            <Sequence name="fireball">
                <MoveTo x="{targetX}" y="{targetY}" duration="0.5"/>
                <PlaySprite sprite="mage_cast" duration="1.0"/>
                <Callback template="deal_damage" damage="25" target="{targetId}" />
                <SpawnEffect effect="fireball" at="{enemyPos}"/>
                <Wait duration="0.5"/>
                <MoveTo x="{originalX}" y="{originalY}" duration="0.5"/>
            </Sequence>

            <Sequence name="meteor">
                <PlaySprite sprite="mage_channel" duration="2.0"/>
                <SpawnEffect effect="meteor_strike" at="{targetArea}"/>
                <Wait duration="1.0"/>
            </Sequence>
        </ActionsComponent>
    </CharacterType>
</CharacterTypes>
