            <TextComponent text="Back to Menu" fontSize="20" r="255" g="255" b="255" a="255"/>
            <UiComponent />
            <ScriptComponent scriptName="Scripts/MenuButton.lua" />
        </Entity>

        <!-- Portrait bar: one slot per selected unit, shown along the bottom of the screen.
             Positions/textures are managed by ExploreScene.lua at runtime. -->
