            <LayerComponent name="ui"/>
            <NameComponent name="PORTRAIT_0"/>
            <PositionComponent x="10" y="400"/>
            <RectangleComponent width="64" height="64" background="#00000000" border="#00000000"/>
        </Entity>
        <Entity name="PORTRAIT_1">
