<AbilityDefinitions>
  <Ability Id="charge" Name="Charge" Type="Active">
    <Description>Rush forward, dealing damage and stunning enemies</Description>
    <Icon>icons/abilities/charge.png</Icon>
    <Animation>charge_forward</Animation>
    
    <Costs>
      <ManaCost>60</ManaCost>
      <StaminaCost>20</StaminaCost>
      <Cooldown>12.0</Cooldown>
    </Costs>
    
    <Targeting>
      <Type>Ground</Type>
      <Range>600</Range>
      <RequiresLineOfSight>false</RequiresLineOfSight>
    </Targeting>
    
    <Effects>
      <Effect Type="Damage" Amount="80" DamageType="Physical" />
      <Effect Type="Stun" Duration="1.5" />
      <Effect Type="Knockback" Distance="200" />
    </Effects>
    
    <Scaling>
      <ManaCost PerLevel="20" />
      <Damage PerLevel="40" />
      <Cooldown PerLevel="-1.0" />
      <StunDuration PerLevel="0.3" />
    </Scaling>
    
    <Requirements>
      <MinLevel>1</MinLevel>
      <Class>Warrior</Class>
    </Requirements>
  </Ability>

  <Ability Id="battle_cry" Name="Battle Cry" Type="Active">
    <Description>Boost nearby allies' attack damage and speed</Description>
    <Icon>icons/abilities/battle_cry.png</Icon>
    
    <Costs>
      <ManaCost>100</ManaCost>
      <Cooldown>45.0</Cooldown>
    </Costs>
    
    <Targeting>
      <Type>Self</Type>
      <AoeRadius>400</AoeRadius>
    </Targeting>
    
    <Effects>
      <Effect Type="Buff" Target="AlliesInRange" Duration="15.0">
        <StatModifier Stat="AttackDamage" Value="25" Type="Additive" />
        <StatModifier Stat="AttackSpeed" Value="0.2" Type="Additive" />
      </Effect>
    </Effects>
    
    <Scaling>
      <ManaCost PerLevel="20" />
      <Duration PerLevel="3.0" />
      <AttackDamageBonus PerLevel="15" />
    </Scaling>
  </Ability>

  <Ability Id="fireball" Name="Fireball" Type="Active">
    <Description>Launch a fireball that explodes on impact</Description>
    <Icon>.Assets/Icons/Abilities/Fireball.png</Icon>
    
    <Costs>
      <ManaCost>80</ManaCost>
      <Cooldown>6</Cooldown>
    </Costs>
    
    <Targeting>
      <Type>Unit</Type>
      <Range>800</Range>
      <RequiresLineOfSight>true</RequiresLineOfSight>
    </Targeting>
    
    <Effects>
      <Effect Type="Projectile" Speed="1200" />
      <Effect Type="Damage" Amount="120" DamageType="Magic" />
      <Effect Type="AreaDamage" Radius="200" Amount="60" DamageType="Magic" />
    </Effects>
    
    <Scaling>
      <Damage PerLevel="60" />
      <AreaDamage PerLevel="30" />
      <ManaCost PerLevel="15" />
    </Scaling>
  </Ability>

  <Ability Id="sword_mastery" Name="Sword Mastery" Type="Passive">
    <Description>Increases damage and critical chance when wielding swords</Description>
    <Icon>icons/abilities/sword_mastery.png</Icon>
    
    <Effects>
      <Effect Type="ConditionalBuff" Condition="EquippedWeaponType=Sword">
        <StatModifier Stat="AttackDamage" Value="15" Type="Percentage" />
        <StatModifier Stat="CriticalChance" Value="8" Type="Additive" />
      </Effect>
    </Effects>
    
    <Scaling>
      <AttackDamageBonus PerLevel="5" />
      <CriticalChance PerLevel="2" />
    </Scaling>
  </Ability>
</AbilityDefinitions>