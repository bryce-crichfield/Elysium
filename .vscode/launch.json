{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug Elysium",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/Binary/Elysium.exe",
            "args": [],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}/Binary",
            "externalConsole": false,
            "MIMode": "gdb",
            "miDebuggerPath": "C:/msys64/mingw64/bin/gdb.exe",
            "setupCommands": [
                {
                    "description": "Enable pretty-printing for gdb",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                }
            ],
            "preLaunchTask": "Build Debug",
            "environment": [
                {
                    "name": "PATH",
                    "value": "C:\\msys64\\mingw64\\bin;${env:PATH}"
                }
            ]
        },
        {
            "name": "Debug Elysium (No Build)",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/Binary/Elysium.exe",
            "args": [],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}/Binary",
            "environment": [
                {
                    "name": "PATH",
                    "value": "C:\\msys64\\mingw64\\bin;${env:PATH}"
                }
            ],
            "preLaunchTask": "Build Debug",
            "externalConsole": false,
            "MIMode": "gdb",
            "miDebuggerPath": "C:/msys64/mingw64/bin/gdb.exe",
            "setupCommands": [
                {
                    "description": "Enable pretty-printing for gdb",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                }
            ]
        }
    ]
}
