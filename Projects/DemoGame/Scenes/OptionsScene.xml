<Scene type="OptionsScene">
    <SceneScript path="Scripts/Scenes/OptionsScene.lua" />

    <Systems>
        <System type="ScriptSystem" />
        <System type="TransformSystem" />
        <System type="UiSystem" />
        <System type="RenderSystem" />
    </Systems>

    <!-- Framebuffer is 640 × 480 -->
    <SceneConfiguration width="640" height="480">
        <SceneLayer name="overlay" z="0" space="Screen" layerBlend="Normal" compositeBlend="Normal" isComposited="false" />
        <SceneLayer name="ui"      z="1" space="Screen" layerBlend="Normal" compositeBlend="Normal" isComposited="false" />
    </SceneConfiguration>

    <Entities>
        <Entity>
            <NameComponent name="CAMERA" />
            <TransformComponent x="0" y="0" />
            <CameraComponent />
        </Entity>

        <!-- Backdrop -->
        <Entity>
            <LayerComponent name="overlay" />
            <NameComponent name="BACKDROP" />
            <TransformComponent x="0" y="0" />
            <RectangleComponent width="640" height="480" background="#000000BB" />
        </Entity>

        <!-- Modal panel: 260 wide, centred horizontally at x=190 -->
        <Entity>
            <LayerComponent name="ui" />
            <NameComponent name="OPTS_PANEL" />
            <TransformComponent x="190" y="80" />
            <RectangleComponent width="260" height="320" background="#1C1C1EFF" border="#4A4A52FF" />
        </Entity>

        <!-- Title -->
        <Entity>
            <LayerComponent name="ui" />
            <NameComponent name="OPTS_TITLE" />
            <TransformComponent x="255" y="94" />
            <TextComponent text="Options" fontSize="18" color="#E5E5EAFF" />
        </Entity>

        <!-- ─────────────────────────────────────────────────────────── -->
        <!--  Button column                                              -->
        <!--                                                             -->
        <!--  OPTS_BUTTONS (Vertical, gap=10) at (206, 128)             -->
        <!--    RESUME_BTN    260 × 36                                   -->
        <!--    AUDIO_BTN     260 × 36                                   -->
        <!--    VIDEO_BTN     260 × 36                                   -->
        <!--    CONTROLS_BTN  260 × 36                                   -->
        <!--    BACK_BTN      260 × 36                                   -->
        <!-- ─────────────────────────────────────────────────────────── -->
        <Entity>
            <NameComponent name="OPTS_BUTTONS" />
            <TransformComponent x="206" y="128" />
            <UiComponent containerType="Vertical" gap="10" />
        </Entity>

        <Entity>
            <LayerComponent name="ui" />
            <NameComponent name="RESUME_BTN" />
            <TransformComponent x="0" y="0" />
            <RectangleComponent width="228" height="36" background="#2A2A2EFF" border="#5A5A62FF" />
            <TextComponent text="Resume" fontSize="16" color="#E5E5EAFF" />
            <UiComponent />
            <ParentComponent target="OPTS_BUTTONS" />
        </Entity>

        <Entity>
            <LayerComponent name="ui" />
            <NameComponent name="AUDIO_BTN" />
            <TransformComponent x="0" y="0" />
            <RectangleComponent width="228" height="36" background="#2A2A2EFF" border="#3A3A42FF" />
            <TextComponent text="Audio Settings" fontSize="16" color="#8E8E93FF" />
            <UiComponent />
            <ParentComponent target="OPTS_BUTTONS" />
        </Entity>

        <Entity>
            <LayerComponent name="ui" />
            <NameComponent name="VIDEO_BTN" />
            <TransformComponent x="0" y="0" />
            <RectangleComponent width="228" height="36" background="#2A2A2EFF" border="#3A3A42FF" />
            <TextComponent text="Video Settings" fontSize="16" color="#8E8E93FF" />
            <UiComponent />
            <ParentComponent target="OPTS_BUTTONS" />
        </Entity>

        <Entity>
            <LayerComponent name="ui" />
            <NameComponent name="CONTROLS_BTN" />
            <TransformComponent x="0" y="0" />
            <RectangleComponent width="228" height="36" background="#2A2A2EFF" border="#3A3A42FF" />
            <TextComponent text="Controls" fontSize="16" color="#8E8E93FF" />
            <UiComponent />
            <ParentComponent target="OPTS_BUTTONS" />
        </Entity>

        <Entity>
            <LayerComponent name="ui" />
            <NameComponent name="BACK_BTN" />
            <TransformComponent x="0" y="0" />
            <RectangleComponent width="228" height="36" background="#2A1C1CFF" border="#6A3030FF" />
            <TextComponent text="Back to Main Menu" fontSize="16" color="#FF9580FF" />
            <UiComponent />
            <ParentComponent target="OPTS_BUTTONS" />
        </Entity>

        <!-- ESC hint -->
        <Entity>
            <LayerComponent name="ui" />
            <NameComponent name="ESC_HINT" />
            <TransformComponent x="220" y="410" />
            <TextComponent text="ESC to resume" fontSize="12" color="#636366FF" />
        </Entity>
    </Entities>
</Scene>
