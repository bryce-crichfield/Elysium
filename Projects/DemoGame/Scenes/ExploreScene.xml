<Scene type="ExploreScene">
    <SceneScript path="Scripts/Scenes/ExploreScene.lua" />

    <Systems>
        <System type="SpatialSystem" />
        <System type="MovementSystem" />
        <System type="KinematicsSystem" />
        <System type="CollisionSystem" />
        <!-- <System type="PhysicsResponseSystem" /> -->
        <System type="ScriptSystem" />
        <System type="SpriteSystem" />
        <System type="TileSystem" />
        <System type="FollowSystem" />
        <System type="TransformSystem" />
        <System type="VisibilitySystem" />
        <System type="UiSystem" />
        <System type="RenderSystem" />
    </Systems>

    <!-- TODO: Utilize width and height from SceneConfiguration -->
    <SceneConfiguration width="800" height="600">
        <SceneLayer name="background" z="-2" space="World"  layerBlend="Normal"   compositeBlend="Normal"   isComposited="false" />
        <SceneLayer name="default"    z="-1" space="World"  layerBlend="Normal"   compositeBlend="Normal"   isComposited="false" />
        <SceneLayer name="tile"       z="0"  space="World"  layerBlend="Normal"   compositeBlend="Normal"   isComposited="false" />
        <SceneLayer name="selection"  z="1"  space="World"  layerBlend="Normal"   compositeBlend="Normal"   isComposited="false" />
        <SceneLayer name="entity"     z="2"  space="World"  layerBlend="Normal"   compositeBlend="Normal"   isComposited="false" />
        <SceneLayer name="light"      z="4"  space="World"  layerBlend="Additive" compositeBlend="Normal"   isComposited="false" />
        <SceneLayer name="shadow"     z="5"  space="World"  layerBlend="Normal"   compositeBlend="Multiply" isComposited="true"  ambient="#000000" />
        <SceneLayer name="ui"         z="10" space="Screen" layerBlend="Normal"   compositeBlend="Normal"   isComposited="false" />
    </SceneConfiguration>

    <PrefabInstance src="Prefabs/Unit.xml" id="Knight1">
        <Override entity="0" component="TransformComponent" field="x" value="320" />
        <Override entity="0" component="TransformComponent" field="y" value="480" />
        <Override entity="0" component="NameComponent" field="name" value="Knight1" />
    </PrefabInstance>

    <Entities>
        <Entity>
            <NameComponent name="CAMERA" />
            <TransformComponent />
            <CameraComponent target="ENTITY_0" zoom="1" />
        </Entity>

        <Entity>
            <NameComponent name="Uno" />
            <TransformComponent x="100" y="100" />
            <LayerComponent layer="entity" />
            <TextureComponent texture="/Textures/Tiles/tile.png" sourceRect="0,0,32,32" />
        </Entity>
    </Entities>
</Scene>
